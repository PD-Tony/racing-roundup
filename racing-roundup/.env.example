# Database Configuration
MONGODB_URI=mongodb://localhost:27017/racing-roundup

# API Keys (Add your own keys when setting up)
F1_API_KEY=your_f1_api_key_here
MOTOGP_API_KEY=your_motogp_api_key_here

# Application Settings
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Racing Roundup
NEWS_FETCH_INTERVAL=3600000  # 1 hour in milliseconds

# Email Configuration (for newsletters)
EMAIL_SERVER=smtp://username:password@smtp.example.com:587
EMAIL_FROM=news@racingroundup.com
